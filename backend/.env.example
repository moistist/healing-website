# OpenAI 兼容 API 配置（服务端统一配置）
# 在此处填写后端实际使用的 LLM 配置，对所有用户生效
# 也可以通过 `export` 环境变量方式设置，会覆盖文件中的值

# ===== 必填：API 密钥 =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 可选：API 基础地址 =====
# 默认值（OpenAI 官方）：https://api.openai.com/v1
# 常用国内/中转示例：
#   - https://api.deepseek.com/v1
#   - https://dashscope.aliyuncs.com/compatible-mode/v1
#   - https://api.moonshot.cn/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 可选：模型名称 =====
# 默认值：gpt-3.5-turbo
OPENAI_MODEL=gpt-3.5-turbo

# ===== 可选：应用配置 =====
APP_NAME=Healing AI Backend
DEBUG=false
